{
  "name": "linkraft",
  "version": "0.1.0",
  "description": "Open-source toolkit that connects Claude Code to any service via MCP servers",
  "private": true,
  "workspaces": [
    "core",
    "generator",
    "packs/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "typecheck": "tsc --noEmit",
    "validate-pack": "node scripts/validate-pack.js",
    "health-check": "node scripts/health-check.js"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "model-context-protocol",
    "ai-tools",
    "api-integration"
  ],
  "author": "Akella inMotion (Nikita)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akellaluvlace/Linkraft"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
