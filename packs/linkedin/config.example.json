{
  "name": "linkedin",
  "version": "0.1.0",
  "auth": {
    "type": "oauth2",
    "clientId": "YOUR_CLIENT_ID",
    "clientSecret": "YOUR_CLIENT_SECRET",
    "scopes": ["openid", "profile", "email", "w_member_social"]
  },
  "rateLimits": {
    "requestsPerMinute": 100,
    "requestsPerDay": 100000,
    "retryOnRateLimit": true,
    "retryMaxAttempts": 3,
    "retryBackoffMs": 1000
  },
  "transport": {
    "type": "stdio"
  },
  "logging": {
    "level": "info"
  }
}
