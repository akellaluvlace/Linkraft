{
  "name": "google-sheets",
  "version": "0.1.0",
  "auth": {
    "type": "oauth2",
    "clientId": "YOUR_CLIENT_ID",
    "clientSecret": "YOUR_CLIENT_SECRET",
    "scopes": ["https://www.googleapis.com/auth/spreadsheets"]
  },
  "rateLimits": {
    "requestsPerMinute": 60,
    "requestsPerDay": 500000,
    "retryOnRateLimit": true,
    "retryMaxAttempts": 3,
    "retryBackoffMs": 1000
  },
  "transport": {
    "type": "stdio"
  },
  "logging": {
    "level": "info"
  }
}
