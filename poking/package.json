{
  "name": "poking-is-new-coding",
  "displayName": "PokingIsNewCoding",
  "description": "Click any element in your app, Claude gets full context: component, file, line, styles, props. Stop describing. Start pointing.",
  "version": "0.1.0",
  "publisher": "akellainmotion",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "frontend",
    "inspector",
    "react",
    "ui"
  ],
  "activationEvents": [
    "onCommand:poking.open"
  ],
  "main": "./dist/extension/activate.js",
  "contributes": {
    "commands": [
      {
        "command": "poking.open",
        "title": "Poke: Open Preview Inspector"
      },
      {
        "command": "poking.toggle",
        "title": "Poke: Toggle Poke Mode"
      },
      {
        "command": "poking.parent",
        "title": "Poke: Select Parent Element"
      },
      {
        "command": "poking.off",
        "title": "Poke: Disable Poke Mode"
      }
    ]
  },
  "scripts": {
    "build": "npm run build:overlay && tsc",
    "build:overlay": "webpack --config webpack.config.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "vsce package"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.85.0",
    "jsdom": "^29.0.1",
    "ts-loader": "^9.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
